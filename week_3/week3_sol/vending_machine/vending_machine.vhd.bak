library ieee;
use ieee.std_logic_1164.all;

entity vending_machine is
	port (
		clk: in std_logic;
		reset: in std_logic;
		coin5: out std_logic;
		coin10: out std_logic;
		dispense: out std_logic;
		change: out std_logic
	); 
end vending_machine;

architecture rtl of vending_machine is
	type state_t is (S0,S5,S10,DISP,DISP_C);
	signal current_state: state_t;
	signal next_state: state_t;
begin
	state_reg: process(clk)
	begin
		if rising_edge(clk) then
			if resert='1' then
				current_state <= S0;
			else
				current_state <= next_state;
			end if;
		end if;
	end process state_reg;
	
	comb_logic: process(current_state, 
	begin
		next_state <= current_state;
		dispense <= '0';
		change <= '0';
		
		case current_state is
			
			when S0=>
				if coin5='1' then next_state<=S5;
				elsif coin10='1' then next_state<=S10;
				end if;
				
			when S5=>
				if coin5='1' then next_state<=S10;
				if coin10='1' then next_state<=DISP;
				end if;
			
			when S10=>
				if coin5=1' then next_state<=DISP;
				if coin10='1' then next_state<=DISP_C;
				end if;
				
			when DISP=>
				dispense<='1';
				change<='0';
				next_state<=S0;
				
			when DISP_C=>
				dispense<='1';
				change<='1';
				next_state<=S0;
				
		end_case;
	end process comb_logic;

end architecture rtl;