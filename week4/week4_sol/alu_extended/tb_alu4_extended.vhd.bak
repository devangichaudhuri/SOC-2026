library IEEE;
use IEEE.STD_LOGIC_1164.ALL;

entity tb_alu4_extended is
end tb_alu4_extended;

architecture sim of tb_alu4_extended is

    signal a, b  : std_logic_vector(3 downto 0) := (others => '0');
    signal op    : std_logic_vector(2 downto 0) := (others => '0');
    signal result : std_logic_vector(3 downto 0);
    signal zero, carry, negative : std_logic;
	 
	 constant PROP_DELAY : time := 10 ns;

begin

    uut: entity work.alu4_extended port map (a, b, op, result, zero, carry, negative);

    stimulus: process
    begin
        -- ADD: 7+1=8, carry=0, negative=1
        a <= "0111"; b <= "0001"; op <= "000"; wait for 20 ns;

        -- ADD: 15+1=16, carry=1, zero=1
        a <= "1111"; b <= "0001"; op <= "000"; wait for 20 ns;

        -- SUB: 5-3=2
        a <= "0101"; b <= "0011"; op <= "001"; wait for 20 ns;

        -- AND
        a <= "1100"; b <= "1010"; op <= "010"; wait for 20 ns;

        -- OR
        a <= "1100"; b <= "1010"; op <= "011"; wait for 20 ns;

        -- XOR: 1010 xor 1010 = 0000, zero=1
        a <= "1010"; b <= "1010"; op <= "100"; wait for 20 ns;

        -- NOT: not 1000 = 0111
        a <= "1000"; b <= "0000"; op <= "101"; wait for 20 ns;

        -- NEGATE: -3 = 1101, negative=1
        a <= "0011"; b <= "0000"; op <= "110"; wait for 20 ns;

        -- op=111: result=0000, all flags 0
        a <= "1111"; b <= "1111"; op <= "111"; wait for 20 ns;

        -- Extra: ADD producing negative=1 (no carry)
        a <= "0111"; b <= "0010"; op <= "000"; wait for 20 ns;

        wait;
    end process;

end sim;